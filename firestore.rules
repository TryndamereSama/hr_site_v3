rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null && (
        request.auth.token.email.matches('.*@mc1global[.]com') ||
        // TEMP: conta de teste — remover antes do deploy em produção
        request.auth.token.email == 'thevinivini100@gmail.com'
      );
    }

    // Comunicados: published articles are public; admins read/write all
    match /comunicados/{docId} {
      allow read:  if resource.data.published == true || isAdmin();
      allow write: if isAdmin();
    }

    // Config (country visibility etc.): public read, admin write
    match /config/{docId} {
      allow read:  if true;
      allow write: if isAdmin();
    }
  }
}
